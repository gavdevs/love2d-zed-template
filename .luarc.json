{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "LuaJIT",

  "diagnostics.disable": [
      // LuaCATS ---@module annotation conflicts with luadoc
      "luadoc-miss-module-name"
  ],
  "diagnostics.globals": [
      "love",
      "jit",
      // busted test framework (spec/)
      "describe", "it", "setup", "teardown", "before_each", "after_each",
      "assert", "spy", "stub", "mock", "finally", "pending"
  ],

  "workspace.checkThirdParty": false,
  "workspace.ignoreDir": [
      ".zed",
      "builds",
      "resources",
      "tools"
  ],
  "workspace.library": [
      "${3rd}/love2d/library",
      "game/lib"
  ]
}
